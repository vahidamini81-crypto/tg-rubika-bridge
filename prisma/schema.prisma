generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model ChatPair {
  telegramChatId String   @id
  rubikaChatId   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AppState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PendingPair {
  code           String   @id
  telegramChatId String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
}

model RubikaProcessedUpdate {
  updateId  String   @id
  createdAt DateTime @default(now())
}

model MediaJob {
  id               String   @id
  status           String
  lane             String   @default("public")
  telegramUpdateId Int
  telegramFileId   String?
  sourceChatId     String
  telegramUserId   Int?
  sourceMessageId  Int?
  senderDisplayName String?
  rubikaChatId     String
  messageType      String
  text             String?
  caption          String?
  originalFilename String?
  mimeType         String?
  fileSize         Int?
  isForwarded      Boolean  @default(false)
  statusMessageId  String?
  error            String?
  attempts         Int      @default(0)
  retryAfter       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
